<?xml version="1.0" encoding="utf-8"?>
<ItemDefinitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../ItemDefinitions.xsd">
    <!-- 示例自定义武器 - 铁剑 -->
    <ItemDefinition Id="Mod_IronSword">
        <Category>MeleeWeapon</Category>
        <Tags>
            <Tag>Sword</Tag>
            <Tag>Metal</Tag>
        </Tags>
        <Hands>OneHand</Hands>
        <LevelVariations>
            <Level Id="0">
                <BaseDamage Min="45" Max="55"/>
                <BasePrice>8</BasePrice>
                <Skills>
                    <Skill>Slice</Skill>
                    <Skill>Slash</Skill>
                </Skills>
            </Level>
            <Level Id="1">
                <BaseDamage Min="52" Max="63"/>
                <BasePrice>12</BasePrice>
                <Skills>
                    <Skill>Slice</Skill>
                    <Skill>Slash</Skill>
                </Skills>
            </Level>
            <Level Id="2">
                <BaseDamage Min="60" Max="72"/>
                <BasePrice>18</BasePrice>
                <Skills>
                    <Skill>Slice</Skill>
                    <Skill>Slash</Skill>
                    <Skill>BladeRush</Skill>
                </Skills>
            </Level>
        </LevelVariations>
    </ItemDefinition>

    <!-- 示例自定义武器 - 魔法杖 -->
    <ItemDefinition Id="Mod_MagicStaff">
        <Category>MagicWeapon</Category>
        <Tags>
            <Tag>Staff</Tag>
            <Tag>Magic</Tag>
        </Tags>
        <Hands>TwoHands</Hands>
        <LevelVariations>
            <Level Id="0">
                <BaseDamage Min="30" Max="40"/>
                <BasePrice>15</BasePrice>
                <BaseStatBonuses>
                    <BaseStatBonus Stat="ManaTotal">5</BaseStatBonus>
                    <BaseStatBonus Stat="MagicalDamage">8</BaseStatBonus>
                </BaseStatBonuses>
                <Skills>
                    <Skill>Fireball</Skill>
                    <Skill>ArcaneBolt</Skill>
                </Skills>
            </Level>
            <Level Id="1">
                <BaseDamage Min="38" Max="50"/>
                <BasePrice>22</BasePrice>
                <BaseStatBonuses>
                    <BaseStatBonus Stat="ManaTotal">8</BaseStatBonus>
                    <BaseStatBonus Stat="MagicalDamage">12</BaseStatBonus>
                </BaseStatBonuses>
                <Skills>
                    <Skill>Fireball</Skill>
                    <Skill>ArcaneBolt</Skill>
                    <Skill>ChainLightning</Skill>
                </Skills>
            </Level>
        </LevelVariations>
    </ItemDefinition>
</ItemDefinitions>
