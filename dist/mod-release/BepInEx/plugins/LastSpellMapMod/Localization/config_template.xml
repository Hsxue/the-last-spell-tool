<?xml version="1.0" encoding="utf-8"?>
<!--
  本地化模组配置文件
  将此文件放在 Mod 根目录（与 Localization 文件夹同级）
  语言名称将显示在游戏设置的语言选择菜单中
-->
<ModConfig>
  <ModName>YourLanguagePack</ModName>
  <Author>YourName</Author>
  <LocalizationModule>
    <FontAssembliesBindings>
      <LanguagesAndFontAssemblies>
        <!-- 语言名称（需与 Localization/ 下文件名一致，不包含 .txt 后缀） -->
        <LanguageIds>YourLanguage</LanguageIds>
        <!-- 字体包 ID，如需自定义字体可在此配置 -->
        <FontAssemblyIds>DefaultFontPack</FontAssemblyIds>
      </LanguagesAndFontAssemblies>
    </FontAssembliesBindings>
  </LocalizationModule>
</ModConfig>
