<?xml version="1.0" encoding="UTF-8"?>
<!--
  示例技能：火焰斩
  前置方向：_M_
           _X_
  将此文件放入 Skills 文件夹后，通过 WebDev2 的「武器与技能」Tab 导入到游戏。
-->
<SkillDefinition Id="FlameSlash">
    <!-- 消耗：1 AP -->
    <ActionPointsCost>1</ActionPointsCost>
    <UsesPerTurnCount>3</UsesPerTurnCount>
    <!-- 射程：相邻 1 格，仅限四向 -->
    <Range Min="1" Max="1" CardinalDirectionOnly="true" Modifiable="true"/>
    <!-- 范围：前置一字型 -->
    <AreaOfEffect OriginX="1" OriginY="0">
        _M_
        _X_
    </AreaOfEffect>
    <!-- 攻击动作 -->
    <SkillAction>
        <Attack>
            <AttackType>Physical</AttackType>
            <!-- 伤害倍率 1.8x -->
            <DamageMultiplier>1.8</DamageMultiplier>
            <SkillEffects>
                <!-- 机动：释放后可额外移动 -->
                <Maneuver/>
                <!-- 灼烧效果：3 回合，每回合 15 伤害 -->
                <Poison>
                    <DamagePerTurn>15</DamagePerTurn>
                    <TurnsCount>3</TurnsCount>
                </Poison>
            </SkillEffects>
        </Attack>
    </SkillAction>
    <!-- 视觉与音效 -->
    <CastFXs TotalDuration="0.4">
        <!-- 施法者挥剑前摇 -->
        <VisualEffect>
            <Paths>
                <Path Orientation="S">FlameSword/FlameSlash/Caster_S</Path>
                <Path Orientation="N">FlameSword/FlameSlash/Caster_N</Path>
                <Path Orientation="W">FlameSword/FlameSlash/Caster_W</Path>
                <Path Orientation="E">FlameSword/FlameSlash/Caster_E</Path>
            </Paths>
            <SortingDepth>Before</SortingDepth>
            <Target>Caster</Target>
        </VisualEffect>
        <!-- 击中火焰特效 -->
        <VisualEffect>
            <Paths>
                <Path Orientation="SNEW">FlameSword/FlameSlash/Target</Path>
            </Paths>
            <Delay>0.3</Delay>
            <SortingDepth>Before</SortingDepth>
            <Target>HitTiles</Target>
        </VisualEffect>
        <!-- 音效 -->
        <SoundEffect>
            <Path>FlameSword/FlameSlash/FireSlash</Path>
            <Delay>0</Delay>
        </SoundEffect>
        <!-- 摄像机震动 -->
        <CamShake>
            <Id>Hard Hit-CamShake</Id>
            <Delay>0.3</Delay>
        </CamShake>
        <!-- 施法动作 -->
        <CasterAnim>
            <Path>Hero_CastSkill_Recoil_</Path>
            <Delay>0.15</Delay>
        </CasterAnim>
    </CastFXs>
</SkillDefinition>
