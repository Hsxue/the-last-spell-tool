<?xml version="1.0" encoding="UTF-8"?>
<!--
  ArtId 说明：
  - 不指定 ArtId 时，游戏默认使用该武器的 Id (FlameSword) 去查找匹配的美术资源。
  - 指定 ArtId 后（如下例使用 Sword0），将强制复用原版武器 Sword0 的图标、模型和粒子特效。
  - 这是一种快速复用大量原版美术资源的简便方式，无需自行导入图片模型。
-->
<ItemDefinition Id="FlameSword">
    <Category>MeleeWeapon</Category>
    <ArtId>Sword0</ArtId>
    <Tags>
        <Tag>Sword</Tag>
        <Tag>Fire</Tag>
    </Tags>
    <Hands>OneHand</Hands>
    <LevelVariations>
        <!-- 普通品质 (Id=0) -->
        <Level Id="0">
            <BaseDamage Min="65" Max="80"/>
            <BasePrice>25</BasePrice>
            <Skills>
                <Skill>Slice</Skill>
                <Skill>FlameSlash</Skill>
            </Skills>
        </Level>
        <!-- 精良品质 (Id=1) - 增加暴击率 -->
        <Level Id="1">
            <BaseDamage Min="75" Max="92"/>
            <BasePrice>40</BasePrice>
            <BaseStatBonuses>
                <BaseStatBonus Stat="Critical">3</BaseStatBonus>
            </BaseStatBonuses>
            <Skills>
                <Skill>Slice</Skill>
                <Skill>FlameSlash</Skill>
            </Skills>
        </Level>
        <!-- 史诗品质 (Id=3) - 附带生命值 -->
        <Level Id="3">
            <BaseDamage Min="95" Max="115"/>
            <BasePrice>85</BasePrice>
            <BaseStatBonuses>
                <BaseStatBonus Stat="Critical">8</BaseStatBonus>
                <BaseStatBonus Stat="HealthRegen">2</BaseStatBonus>
            </BaseStatBonuses>
            <Skills>
                <Skill>Slice</Skill>
                <Skill>FlameSlash</Skill>
            </Skills>
        </Level>
    </LevelVariations>
</ItemDefinition>
