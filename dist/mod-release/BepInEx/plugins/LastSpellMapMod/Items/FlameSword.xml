<?xml version="1.0" encoding="UTF-8"?>
<!--
  示例武器：单手火焰剑
  将此文件放入 Items 文件夹后，通过 WebDev2 的「武器与技能」Tab 导入到游戏。
-->
<ItemDefinition Id="FlameSword">
    <Category>MeleeWeapon</Category>
    <Tags>
        <Tag>Sword</Tag>
        <Tag>Fire</Tag>
    </Tags>
    <Hands>OneHand</Hands>
    <LevelVariations>
        <!-- 普通品质 (Id=0) -->
        <Level Id="0">
            <BaseDamage Min="65" Max="80"/>
            <BasePrice>25</BasePrice>
            <Skills>
                <Skill>Slice</Skill>
                <Skill>FlameSlash</Skill>
            </Skills>
        </Level>
        <!-- 精良品质 (Id=1) - 增加暴击率 -->
        <Level Id="1">
            <BaseDamage Min="75" Max="92"/>
            <BasePrice>40</BasePrice>
            <BaseStatBonuses>
                <BaseStatBonus Stat="Critical">3</BaseStatBonus>
            </BaseStatBonuses>
            <Skills>
                <Skill>Slice</Skill>
                <Skill>FlameSlash</Skill>
            </Skills>
        </Level>
        <!-- 史诗品质 (Id=3) - 附带生命值 -->
        <Level Id="3">
            <BaseDamage Min="95" Max="115"/>
            <BasePrice>85</BasePrice>
            <BaseStatBonuses>
                <BaseStatBonus Stat="Critical">8</BaseStatBonus>
                <BaseStatBonus Stat="HealthRegen">2</BaseStatBonus>
            </BaseStatBonuses>
            <Skills>
                <Skill>Slice</Skill>
                <Skill>FlameSlash</Skill>
            </Skills>
        </Level>
    </LevelVariations>
</ItemDefinition>
